---
import Countdown from "../components/Countdown.jsx";
import RSVPForm from "../components/RSVPForm.jsx";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Invitación Modelo | VS Web Design</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital@0;1&family=Lato:wght@300;400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="font-['Lato'] text-gray-800 antialiased overflow-x-hidden"
  >
    <section
      id="hero"
      class="min-h-screen flex flex-col justify-center items-center px-4 sm:px-6 text-center relative overflow-hidden"
    >
      <!-- Fondo parallax (capas que se mueven con el scroll) -->
      <div class="parallax-wrap">
        <div class="parallax-layer parallax-layer--base" aria-hidden="true"></div>
        <div class="parallax-layer parallax-layer--mid" aria-hidden="true"></div>
        <div class="parallax-layer parallax-layer--front" aria-hidden="true"></div>
      </div>
      <!-- Transición suave hacia la siguiente sección -->
      <div class="hero-fade" aria-hidden="true"></div>
      <!-- Formas tipo collage (marcos suaves) -->
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="hero-collage hero-collage--1"></div>
        <div class="hero-collage hero-collage--2"></div>
        <div class="hero-collage hero-collage--3"></div>
        <div class="hero-collage hero-collage--4"></div>
        <div class="hero-collage hero-collage--5"></div>
      </div>

      <!-- Botón música: play/pause -->
      <button
        type="button"
        id="music-toggle"
        class="fixed top-5 right-5 z-50 w-12 h-12 rounded-full bg-white/80 backdrop-blur-sm border border-[#C5A059]/30 shadow-lg flex items-center justify-center text-[#C5A059] hover:bg-white hover:scale-105 active:scale-95 transition-all focus:outline-none focus:ring-2 focus:ring-[#C5A059]/50"
        aria-label="Reproducir o pausar música"
      >
        <svg id="icon-music-on" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
        </svg>
        <svg id="icon-music-off" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
        </svg>
      </button>
      <audio id="bg-music" preload="metadata" loop>
        <source src="/music.mp3" type="audio/mpeg" />
      </audio>

      <div class="reveal space-y-8 relative z-10">
        <span
          class="uppercase tracking-[0.6em] text-[9px] sm:text-[10px] md:text-xs opacity-50 block mb-4"
        >
          Save the Date
        </span>

        <div
          class="flex flex-col md:flex-row items-center justify-center gap-1 sm:gap-2 md:gap-6"
        >
          <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-light tracking-tight">
            Vane
          </h1>
          <span
            class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl italic font-serif text-[#C5A059] leading-none my-2 md:my-0"
          >
            &amp;
          </span>
          <h1 class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-light tracking-tight">
            Julián
          </h1>
        </div>

        <div class="flex items-center justify-center gap-3 sm:gap-4 py-6">
          <div class="h-px w-10 sm:w-12 bg-[#C5A059]/30"></div>
          <p
            class="text-base sm:text-lg md:text-xl tracking-[0.4em] font-light uppercase opacity-80"
          >
            20 . 12 . 2026
          </p>
          <div class="h-3 w-10 sm:w-12 bg-[#C5A059]/30 rounded-full"></div>
        </div>
      </div>

      <div
        class="absolute bottom-10 sm:bottom-12 flex flex-col items-center gap-3 opacity-40"
      >
        <span class="text-[9px] uppercase tracking-[0.3em]">Deslizar</span>
        <div
          class="w-px h-12 bg-linear-to-b from-[#C5A059] to-transparent"
        >
        </div>
      </div>
    </section>

    <section class="py-16 px-4 flex flex-col items-center">
      <div
        class="relative w-full max-w-2xl rounded-4xl px-6 sm:px-10 py-10 bg-white/70 backdrop-blur-md shadow-[0_18px_80px_rgba(45,45,45,0.08)] border border-white/70"
      >
        <h3
          class="text-xs uppercase tracking-[0.2em] mb-8 text-gray-400 font-bold text-center"
        >
          Faltan tan solo
        </h3>
        <Countdown client:load />
      </div>
    </section>

    <section class="py-20 px-4">
      <div
        class="relative max-w-4xl mx-auto rounded-[40px] px-6 sm:px-10 py-12 bg-white/75 backdrop-blur-md shadow-[0_20px_90px_rgba(45,45,45,0.10)] border border-white/70"
      >
        <div
          class="max-w-3xl mx-auto grid gap-12 md:gap-16 md:grid-cols-2 items-start"
        >
          <div class="text-center group">
            <div class="text-2xl sm:text-3xl mb-2 italic font-serif">
              Ceremonia
            </div>
            <p class="text-gray-500 mb-4 text-sm sm:text-base">
              Parroquia Central - 20:30 hs
            </p>
            <a
              href="#"
              class="inline-block border-b border-[#D4AF37] pb-1 text-[#D4AF37] text-xs tracking-widest hover:text-black transition-colors"
            >
              VER MAPA
            </a>
          </div>

          <div class="text-center">
            <div
              class="text-2xl sm:text-3xl mb-2 italic font-serif text-[#D4AF37]"
            >
              Fiesta
            </div>
            <p class="text-gray-500 mb-4 text-sm sm:text-base font-bold">
              Salón Las Camelias
            </p>
            <p class="text-xs sm:text-sm text-gray-400 mb-6 italic">
              Calle Falsa 123, San Juan
            </p>
            <a
              href="#"
              class="inline-block bg-[#333] text-white px-8 py-3 rounded-full text-xs sm:text-sm tracking-[0.2em] shadow-lg active:scale-95 transition-transform"
            >
              CÓMO LLEGAR
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 px-4">
      <div
        class="relative w-full max-w-2xl mx-auto rounded-[40px] px-6 sm:px-10 py-14 bg-white/80 backdrop-blur-md shadow-[0_22px_100px_rgba(45,45,45,0.12)] border border-white/80"
      >
        <div class="text-center mb-10">
          <h2 class="text-3xl font-serif italic mb-2">Confirmación</h2>
          <p class="text-xs text-gray-400 uppercase tracking-widest font-bold">
            R.S.V.P
          </p>
        </div>
        <RSVPForm client:visible />
      </div>
    </section>

    <footer
      class="py-10 text-center border-t border-gray-100 italic text-gray-400 text-xs"
    >
      Hecho con ♡ por VS Web Design
    </footer>

    <script>
      (function () {
        const btn = document.getElementById("music-toggle");
        /** @type {HTMLAudioElement | null} */
        const audio = document.getElementById("bg-music");
        const iconOn = document.getElementById("icon-music-on");
        const iconOff = document.getElementById("icon-music-off");

        if (!btn || !audio || !iconOn || !iconOff) return;

        function setPlaying(playing) {
          if (playing) {
            iconOn.classList.add("hidden");
            iconOff.classList.remove("hidden");
          } else {
            iconOn.classList.remove("hidden");
            iconOff.classList.add("hidden");
          }
        }

        btn.addEventListener("click", function () {
          if (audio.paused) {
            audio.play().then(() => setPlaying(true)).catch(() => setPlaying(false));
          } else {
            audio.pause();
            setPlaying(false);
          }
        });

        audio.addEventListener("ended", () => setPlaying(false));
        audio.addEventListener("pause", () => setPlaying(false));
        audio.addEventListener("play", () => setPlaying(true));
      })();

      (function () {
        const hero = document.getElementById("hero");
        const layers = document.querySelectorAll(".parallax-layer--base, .parallax-layer--mid, .parallax-layer--front");
        const factors = [0.08, 0.15, 0.22];
        let ticking = false;

        function updateParallax() {
          const y = window.scrollY;
          const heroHeight = hero ? hero.offsetHeight : window.innerHeight;
          const max = heroHeight;
          const progress = Math.min(y / max, 1);
          layers.forEach((el, i) => {
            const move = progress * max * factors[i];
            /** @type {HTMLElement} */ (el).style.transform = `translate3d(0, ${move * 0.5}px, 0)`;
          });
          ticking = false;
        }

        function onScroll() {
          if (!ticking) {
            requestAnimationFrame(updateParallax);
            ticking = true;
          }
        }

        window.addEventListener("scroll", onScroll, { passive: true });
        updateParallax();
      })();
    </script>
  </body>
</html>

<style is:global>
  @import "tailwindcss";

  :root {
    --gold: #c5a059;
    --dark: #2d2d2d;
    --bg: #f9f7f2;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: "Playfair Display", serif;
    background:
      radial-gradient(circle at top right, rgba(197, 160, 89, 0.22), transparent 55%),
      radial-gradient(circle at 10% 80%, rgba(212, 175, 55, 0.14), transparent 55%),
      linear-gradient(180deg, #fdfbf7 0%, #f7f2e9 45%, #f0e7db 100%);
    color: var(--dark);
    -webkit-font-smoothing: antialiased;
  }

  .gold-text {
    color: var(--gold);
  }
  .gold-border {
    border-color: var(--gold);
  }

  /* Animación de entrada suave */
  .reveal {
    animation: reveal 1.5s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Efecto decorativo del hero */
  .hero-orbit {
    position: absolute;
    inset: 50%;
    border-radius: 9999px;
    border-width: 1px;
    transform-origin: center;
    transform: translate(-50%, -50%);
    animation: heroOrbit 26s linear infinite;
  }

  .hero-orbit--lg {
    width: 110vmin;
    height: 110vmin;
  }

  .hero-orbit--md {
    width: 80vmin;
    height: 80vmin;
    animation-duration: 22s;
    animation-direction: reverse;
  }

  .hero-orbit--sm {
    width: 52vmin;
    height: 52vmin;
    animation-duration: 18s;
  }

  @keyframes heroOrbit {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  /* Parallax: capas de fondo que se mueven a distinta velocidad */
  .parallax-wrap {
    position: absolute;
    inset: -20%;
    pointer-events: none;
    overflow: hidden;
  }

  .parallax-layer {
    position: absolute;
    inset: -10%;
    will-change: transform;
  }

  .parallax-layer--base {
    background:
      radial-gradient(ellipse 80% 60% at 70% 30%, rgba(197, 160, 89, 0.18), transparent 50%),
      radial-gradient(ellipse 60% 80% at 20% 80%, rgba(212, 175, 55, 0.12), transparent 45%);
  }

  .parallax-layer--mid {
    background:
      radial-gradient(circle at 85% 15%, rgba(232, 228, 220, 0.5), transparent 35%),
      radial-gradient(circle at 15% 70%, rgba(197, 160, 89, 0.08), transparent 40%);
  }

  .parallax-layer--front {
    background:
      radial-gradient(ellipse 50% 40% at 50% 90%, rgba(249, 247, 242, 0.9), transparent 50%);
  }

  /* Transición suave hero → siguiente sección (evita corte brusco) */
  .hero-fade {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: min(180px, 25vh);
    pointer-events: none;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(253, 251, 247, 0.4) 40%,
      rgba(247, 242, 233, 0.9) 85%,
      #f7f2e9 100%
    );
  }

  /* Collage: marcos suaves que simulan fotos */
  .hero-collage {
    position: absolute;
    border-radius: 12px;
    box-shadow: 0 4px 24px rgba(197, 160, 89, 0.08);
    animation: heroCollageFloat 12s ease-in-out infinite;
  }

  .hero-collage--1 {
    width: min(140px, 32vw);
    height: min(100px, 24vw);
    top: 12%;
    left: 8%;
    background: linear-gradient(145deg, rgba(197, 160, 89, 0.15), rgba(212, 175, 55, 0.06));
    animation-delay: 0s;
  }

  .hero-collage--2 {
    width: min(100px, 24vw);
    height: min(130px, 30vw);
    top: 18%;
    right: 10%;
    background: linear-gradient(200deg, rgba(233, 228, 220, 0.9), rgba(212, 175, 55, 0.08));
    animation-delay: -2s;
  }

  .hero-collage--3 {
    width: min(120px, 28vw);
    height: min(90px, 22vw);
    bottom: 28%;
    left: 5%;
    background: linear-gradient(160deg, rgba(244, 241, 234, 0.95), rgba(197, 160, 89, 0.1));
    animation-delay: -5s;
  }

  .hero-collage--4 {
    width: min(110px, 26vw);
    height: min(110px, 26vw);
    bottom: 22%;
    right: 6%;
    background: linear-gradient(220deg, rgba(212, 175, 55, 0.12), rgba(249, 247, 242, 0.8));
    animation-delay: -7s;
  }

  .hero-collage--5 {
    width: min(90px, 22vw);
    height: min(70px, 18vw);
    bottom: 38%;
    left: 50%;
    margin-left: min(-45px, -11vw);
    background: linear-gradient(135deg, rgba(197, 160, 89, 0.1), rgba(232, 228, 220, 0.7));
    animation-delay: -3s;
    --r: -6deg;
  }

  @keyframes heroCollageFloat {
    0%, 100% { transform: translateY(0) rotate(var(--r, 0deg)); }
    50% { transform: translateY(-6px) rotate(var(--r, 0deg)); }
  }
</style>
