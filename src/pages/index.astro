---
import Layout from "../layouts/Layout.astro";
import Countdown from "../components/Countdown.jsx";
import RSVPForm from "../components/RSVPForm.jsx";

// import GiftModal from "../components/GiftModal.jsx";
---

<Layout>
  <section
    id="hero"
    class="relative min-h-screen flex flex-col items-center justify-center px-6 overflow-hidden bg-cover bg-center bg-no-repeat"
    style="background-image: url('/hero-bg.jpg');"
  >
    <div class="absolute inset-0 bg-black/60 pointer-events-none z-0"></div>

    <div
      class="relative z-20 text-center flex flex-col items-center w-full max-w-3xl scroll-fade-up"
    >
      <span class="text-sm md:text-base text-[#C5A059] mb-6 font-light">
        15.05.2026
      </span>

      <div class="flex items-center justify-center gap-4 md:gap-6 mb-6">
        <h1 class="text-6xl md:text-8xl font-serif text-white leading-none">
          Mary
        </h1>
        <div
          class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-[#C5A059] flex items-center justify-center text-white font-serif text-2xl md:text-3xl relative"
        >
          &
        </div>
        <h1 class="text-6xl md:text-8xl font-serif text-white leading-none">
          Julián
        </h1>
      </div>

      <div class="w-full h-px bg-white/30 my-4"></div>

      <h2 class="text-3xl md:text-4xl font-serif text-[#C5A059] mb-8">
        Nuestra Boda
      </h2>

      <p
        class="text-sm md:text-base text-white/90 font-light max-w-md mx-auto leading-relaxed"
      >
        Lorem ipsum, dolor sit amet consectetur adipisicing elit.<br />Ipsum aut
        corporis facilis ducimus exercitationem, distinctio eveniet nostrum!
      </p>
    </div>

    <div
      class="absolute bottom-10 flex flex-col items-center gap-4 animate-bounce-slow opacity-80 z-20"
    >
      <span class="text-[9px] uppercase tracking-widest text-white"
        >Deslizar</span
      >
      <div class="w-px h-12 bg-gradient-to-b from-white to-transparent"></div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white text-center">
    <div class="max-w-4xl mx-auto scroll-fade-up">
      <h2 class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-12">
        Falta muy poco
      </h2>
      <div
        class="inline-block border border-gray-100 rounded-3xl p-8 md:p-12 shadow-[0_10px_40px_rgba(0,0,0,0.03)]"
      >
        <Countdown client:load />
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[#FAFAFA]">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-16 md:gap-8">
      <div class="flex flex-col items-center text-center scroll-fade-up">
        <div
          class="animated-icon w-12 h-12 rounded-full border border-[#C5A059] flex items-center justify-center mb-6"
        >
          <svg
            class="w-5 h-5 text-[#C5A059]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1"
              d="M3 21v-4m22 4v-4m-9-4V4m0 13V4m0 0H6m6 0h6"></path>
          </svg>
        </div>
        <h3 class="text-3xl font-serif italic text-gray-900 mb-2">Ceremonia</h3>
        <p class="text-sm uppercase tracking-widest text-gray-500 mb-4">
          20:30 HS
        </p>
        <p class="text-gray-600 font-light mb-6">
          Parroquia Central<br />San Juan
        </p>
        <a
          href="#"
          class="text-[10px] uppercase tracking-[0.2em] text-[#C5A059] border-b border-[#C5A059] pb-1 hover:text-gray-900 hover:border-gray-900 transition-colors"
        >
          Ver Ubicación
        </a>
      </div>

      <div
        class="flex flex-col items-center text-center scroll-fade-up transition-delay-200"
      >
        <div
          class="animated-icon w-12 h-12 rounded-full border border-[#C5A059] flex items-center justify-center mb-6"
        >
          <svg
            class="w-5 h-5 text-[#C5A059]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1"
              d="M12 21a9 9 0 100-18 9 9 0 000 18zM9 10a1 1 0 011-1h4a1 1 0 011 1v2a1 1 0 01-1 1h-4a1 1 0 01-1-1v-2zM8 12a1 1 0 001 1h6a1 1 0 001-1v2a1 1 0 01-1 1h-6a1 1 0 01-1-1v-2z"
            ></path>
          </svg>
        </div>
        <h3 class="text-3xl font-serif italic text-gray-900 mb-2">Fiesta</h3>
        <p class="text-sm uppercase tracking-widest text-gray-500 mb-4">
          22:00 HS
        </p>
        <p class="text-gray-600 font-light mb-6">
          Salón Las Camelias<br />Calle Falsa 123
        </p>
        <a
          href="#"
          class="text-[10px] uppercase tracking-[0.2em] text-[#C5A059] border-b border-[#C5A059] pb-1 hover:text-gray-900 hover:border-gray-900 transition-colors"
        >
          Cómo Llegar
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="bg-[#FAFAFA] p-12 text-center rounded-sm scroll-fade-up">
        <div
          class="animated-icon w-12 h-12 mx-auto rounded-full border border-[#C5A059] flex items-center justify-center mb-6"
        >
          <svg
            class="w-5 h-5 text-[#C5A059]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1"
              d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6zM14 3v5h5M12 12a2 2 0 110-4 2 2 0 010 4zm0 1a4 4 0 00-4 4h8a4 4 0 00-4-4z"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl font-serif italic text-gray-900 mb-4">
          Dress Code
        </h3>
        <p
          class="text-[11px] uppercase tracking-[0.2em] font-bold text-gray-800 mb-4"
        >
          Elegante / Formal
        </p>
        <p class="text-gray-500 text-sm font-light">
          Reserva el color blanco exclusivo para la novia.
        </p>
      </div>

      <div
        class="bg-[#FAFAFA] p-12 text-center rounded-sm scroll-fade-up transition-delay-200"
      >
        <div
          class="animated-icon w-12 h-12 mx-auto rounded-full border border-[#C5A059] flex items-center justify-center mb-6"
        >
          <svg
            class="w-5 h-5 text-[#C5A059]"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1"
              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-14v10m0 0l-8-4m16 0V7m-16 0V7"
            ></path>
          </svg>
        </div>
        <h3 class="text-2xl font-serif italic text-gray-900 mb-4">Regalos</h3>
        <p class="text-gray-500 text-sm font-light mb-8">
          El mejor regalo es tu presencia. Si deseas colaborar con nuestra luna
          de miel, puedes hacerlo aquí.
        </p>
        <button
          class="inline-block border border-[#C5A059] text-[#C5A059] px-6 py-2 rounded-full text-xs tracking-[0.1em] hover:bg-[#C5A059] hover:text-white transition-colors"
        >
          VER DATOS BANCARIOS
        </button>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-[#FAFAFA] text-center border-t border-gray-100">
    <div class="max-w-2xl mx-auto scroll-fade-up">
      <h2 class="text-4xl font-serif italic text-gray-900 mb-4">
        Confirmación
      </h2>
      <p class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-12">
        R.S.V.P
      </p>
      <div class="bg-white p-8 md:p-12 shadow-[0_10px_40px_rgba(0,0,0,0.02)]">
        <RSVPForm client:visible />
      </div>
    </div>
  </section>

  <section class="py-20 px-6 bg-white text-center">
    <div class="scroll-fade-up">
      <p class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-8">
        No olvides la fecha
      </p>
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Boda+de+Mary+y+Julián&dates=20261220T233000Z/20261221T080000Z"
        class="inline-block bg-gray-900 text-white px-10 py-4 text-[10px] tracking-[0.2em] uppercase hover:bg-[#C5A059] transition-colors"
      >
        Agendar Evento
      </a>
    </div>
  </section>

  <footer class="py-12 text-center border-t border-gray-100 bg-[#FAFAFA]">
    <p class="text-gray-400 text-[10px] uppercase tracking-[0.2em]">
      Hecho con ♡ por <span class="text-gray-800 font-bold">VS Web Design</span>
    </p>
  </footer>

  <button
    type="button"
    id="music-toggle"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center transition-all duration-300 shadow-[0_6px_25px_rgba(197,160,89,0.15)] border bg-white border-gray-100 hover:scale-105 active:scale-95 group focus:outline-none"
    aria-label="Reproducir o pausar música"
  >
    <svg
      id="music-note-icon"
      class="w-6 h-6 text-[#C5A059] transition-colors duration-300"
      fill="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"
      ></path>
    </svg>
  </button>

  <audio id="bg-music" loop preload="none">
    <source src="/music.mp3" type="audio/mpeg" />
  </audio>

  <script>
    // Observador de intersección para las animaciones al hacer scroll
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 },
    );

    document.querySelectorAll(".scroll-fade-up").forEach((el) => {
      observer.observe(el);
    });

    // Audio
    const musicBtn = document.getElementById(
      "music-toggle",
    ) as HTMLButtonElement | null;
    const bgAudio = document.getElementById(
      "bg-music",
    ) as HTMLAudioElement | null;
    const noteIcon = document.getElementById("music-note-icon");

    if (musicBtn && bgAudio && noteIcon) {
      musicBtn.addEventListener("click", () => {
        if (bgAudio.paused) {
          bgAudio
            .play()
            .then(() => {
              musicBtn.classList.remove("bg-white", "border-gray-100");
              musicBtn.classList.add("bg-[#C5A059]", "border-[#C5A059]");
              noteIcon.classList.remove("text-[#C5A059]");
              noteIcon.classList.add("text-white");
              noteIcon.classList.add("animate-note-float");
              musicBtn.setAttribute("aria-label", "Pausar música");
            })
            .catch((error) => {
              console.error(
                "La reproducción automática fue bloqueada o falló:",
                error,
              );
              alert(
                "Por favor, interactúa con la página primero para reproducir la música.",
              );
            });
        } else {
          bgAudio.pause();
          musicBtn.classList.add("bg-white", "border-gray-100");
          musicBtn.classList.remove("bg-[#C5A059]", "border-[#C5A059]");
          noteIcon.classList.add("text-[#C5A059]");
          noteIcon.classList.remove("text-white");
          noteIcon.classList.remove("animate-note-float");
          musicBtn.setAttribute("aria-label", "Reproducir música");
        }
      });
    }
  </script>
</Layout>
